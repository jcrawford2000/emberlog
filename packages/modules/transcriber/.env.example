EMBERLOG_INBOX_DIR="/data/emberlog/inbox"
EMBERLOG_OUTBOX_DIR="/data/emberlog/outbox"
EMBERLOG_LEDGER_PATH="/data/emberlog/ledger.jsonl"
EMBERLOG_AUDIO_EXTENSIONS=[".wav",".mp3"]
EMBERLOG_CONCURRENCY=1
EMBERLOG_SCAN_EXISTING_ON_START=true
EMBERLOG_TRANSCRIBER_BACKEND="faster_whisper"
EMBERLOG_MAX_WORKERS=2
EMBERLOG_LOG_LEVEL="DEBUG"


EMBERLOG_WHISPER_MODEL="medium.en"
EMBERLOG_WHISPER_DEVICE="cuda"
EMBERLOG_WHISPER_COMPUTE_TYPE="float32"
EMBERLOG_WHISPER_VAD_FILTER=true
EMBERLOG_WHISPER_VAD_PARAMETERS="{'min_silence_duration_ms': 250}"
EMBERLOG_WHISPER_BEAM_SIZE=5
EMBERLOG_WHISPER_LANGUAGE="en"
EMBERLOG_WHISPER_BEST_OF=8
EMBERLOG_WHISPER_TEMPERATURE=0.0
EMBERLOG_WHISPER_INITIAL_PROMPT="Phoenix metro fire dispatch. Terms: K-Deck, Battalion, Engine, Ladder, Ladder Tender, Rescue, Medic, HazMat. Street names: Civic Center Plaza, Watson, Yuma, Buckeye. Spell out channels like 'K-Deck 10'."
EMBERLOG_WHISPER_NO_SPEECH_THRESHOLD=0.3
EMBERLOG_WHISPER_LOG_PROB_THRESHOLD=-1.2
EMBERLOG_WHISPER_COMPRESSION_RATIO_THRESHOLD=2.8
