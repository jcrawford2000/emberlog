# Emberlog API - environment example
# Copy to packages/api/.env

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Base URL as seen by other components (web, transcriber)
# Use the reachable hostname/IP in distributed deployments.
API_PUBLIC_BASE_URL=http://localhost:8000

# Database (adjust to your deployment)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=emberlog
POSTGRES_USER=emberlog
POSTGRES_PASSWORD=emberlog
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5

# MQTT (if API is consuming stats/traffic via MQTT)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false

# Logging
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=false

# Notifier Settings
NOTIFIER_BASE_URL=http://localhost:8090
