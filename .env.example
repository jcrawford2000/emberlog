EMBERLOG_INBOX_DIR="/data/emberlog/inbox"
EMBERLOG_OUTBOX_DIR="/data/emberlog/outbox"
EMBERLOG_LEDGER_PATH="/data/emberlog/ledger.jsonl"
EMBERLOG_AUDIO_EXTENSIONS=[".wav",".mp3"]
EMBERLOG_CONCURRENCY=1
EMBERLOG_SCAN_EXISTING_ON_START=true
EMBERLOG_TRANSCRIBER_BACKEND="faster_whisper"
EMBERLOG_MAX_WORKERS=2
EMBERLOG_LOG_LEVEL="DEBUG"


WHISPER_MODEL="medium.en"
WHISPER_DEVICE="cuda"
WHISPER_COMPUTE_TYPE="float32"
WHISPER_VAD_FILTER=true
WHISPER_VAD_PARAMETERS="{'min_silence_duration_ms': 250}"
WHISPER_BEAM_SIZE=5
WHISPER_LANGUAGE="en"
WHISPER_BEST_OF=8
WHISPER_TEMPERATURE=0.0
WHISPER_INITIAL_PROMPT="Phoenix metro fire dispatch. Terms: K-Deck, Battalion, Engine, Ladder, Ladder Tender, Rescue, Medic, HazMat. Street names: Civic Center Plaza, Watson, Yuma, Buckeye. Spell out channels like 'K-Deck 10'."
WHISPER_NO_SPEECH_THRESHOLD=0.3
WHISPER_LOG_PROB_THRESHOLD=-1.2
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.8
